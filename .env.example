# Copia este archivo como .env y llena los valores
# NUNCA subas el archivo .env a GitHub

# URL de tu base de datos PostgreSQL en Railway
# Ejemplo: postgresql://postgres:tupassword@hostname:5432/railway
DATABASE_URL=postgresql://usuario:password@host:puerto/nombre_db

# Puerto donde corre el servidor (Railway lo asigna automáticamente)
PORT=3000

# Clave secreta para validar que los webhooks vienen de Smartlead
# La encuentras en Smartlead > Settings > Webhooks
SMARTLEAD_SECRET=tu_secret_key_de_smartlead

# Clave para proteger el acceso al CRM (la que tú elijas)
API_KEY=pon_aqui_una_clave_segura_que_tu_elijas
